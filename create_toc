#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 2 ]; then
  echo "Usage: $0 <documents_dir> <index_md_file>" >&2
  exit 1
fi

DIR="$1"
OUT="$2"

if [ ! -d "$DIR" ]; then
  echo "Error: directory '$DIR' does not exist" >&2
  exit 1
fi

tmpfile="$(mktemp)"

for file in "$DIR"/*.md; do
  [ "$file" = "$OUT" ] && continue

  adr="$(awk -F': *' '/^adr:/ {print $2; exit}' "$file")"
  title="$(awk -F': *' '/^title:/ {print $2; exit}' "$file")"

  [ -z "$adr" ] && continue
  [ -z "$title" ] && title="$(basename "$file")"

  name="$(basename "$file")"

  printf "%06d|* [%s](%s)\n" "$adr" "$title" "$name" >> "$tmpfile"
done

echo "# # [Architecture Decision Records](_sidebar.md)" > "$OUT"
echo >> "$OUT"
sort -n "$tmpfile" | cut -d'|' -f2- >> "$OUT"

rm "$tmpfile"
